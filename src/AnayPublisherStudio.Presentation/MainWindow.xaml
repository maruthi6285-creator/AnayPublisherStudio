<Window x:Class="AnayPublisherStudio.Presentation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Anay Publisher Studio" Height="860" Width="1400"
        Background="{DynamicResource WindowBackground}">
    <DockPanel>
        <!-- Office-style ribbon -->
        <TabControl DockPanel.Dock="Top" Height="130">
            <TabItem Header="Home">
                <StackPanel Orientation="Horizontal">
                    <Button Content="Open Manuscript" Margin="6" Padding="12,6"
                            Command="{Binding OpenManuscriptCommand}"/>
                    <Button Content="Save Project" Margin="6" Padding="12,6"
                            Command="{Binding SaveProjectCommand}"/>
                    <Button Content="Publish (Export All)" Margin="6" Padding="12,6"
                            Command="{Binding PublishCommand}"/>
                    <Separator Margin="8,4"/>
                    <Button Content="Refresh Preview" Margin="6" Padding="12,6"
                            Command="{Binding RefreshPreviewCommand}"/>
                </StackPanel>
            </TabItem>
            <TabItem Header="Layout">
                <StackPanel Orientation="Horizontal">
                    <Button Content="Single Page" Margin="6" Padding="12,6" Command="{Binding PreviewSingleCommand}"/>
                    <Button Content="Facing Pages" Margin="6" Padding="12,6" Command="{Binding PreviewFacingCommand}"/>
                    <Button Content="Continuous" Margin="6" Padding="12,6" Command="{Binding PreviewContinuousCommand}"/>
                    <Button Content="Toggle Guides" Margin="6" Padding="12,6" Command="{Binding ToggleGuidesCommand}"/>
                    <Button Content="Zoom +" Margin="6" Padding="12,6" Command="{Binding ZoomInCommand}"/>
                    <Button Content="Zoom -" Margin="6" Padding="12,6" Command="{Binding ZoomOutCommand}"/>
                </StackPanel>
            </TabItem>
            <TabItem Header="Styles"/>
            <TabItem Header="Typography">
                <TextBlock Margin="12" VerticalAlignment="Center"
                           Text="Typography is template-driven (OpenType, ligatures, kerning, drop caps). Author text is never modified."/>
            </TabItem>
            <TabItem Header="Cover">
                <StackPanel Orientation="Horizontal">
                    <Button Content="Design Cover" Margin="6" Padding="12,6" Command="{Binding DesignCoverCommand}"/>
                    <Button Content="Validate Cover" Margin="6" Padding="12,6" Command="{Binding ValidateCoverCommand}"/>
                </StackPanel>
            </TabItem>
            <TabItem Header="AI">
                <StackPanel Orientation="Horizontal">
                    <Button Content="Generate Description" Margin="6" Padding="12,6"
                            Command="{Binding GenerateDescriptionCommand}"/>
                    <Button Content="Suggest Keywords" Margin="6" Padding="12,6"
                            Command="{Binding SuggestKeywordsCommand}"/>
                    <Button Content="Checklist" Margin="6" Padding="12,6"
                            Command="{Binding SuggestChecklistCommand}"/>
                    <Button Content="Suggest TOC" Margin="6" Padding="12,6"
                            Command="{Binding SuggestTocCommand}"/>
                </StackPanel>
            </TabItem>
            <TabItem Header="Review">
                <StackPanel Orientation="Horizontal">
                    <Button Content="Run Preflight" Margin="6" Padding="12,6" Command="{Binding RunPreflightCommand}"/>
                </StackPanel>
            </TabItem>
            <TabItem Header="Export">
                <StackPanel Orientation="Horizontal">
                    <Button Content="Print PDF" Margin="6" Padding="12,6" Command="{Binding PublishCommand}"/>
                    <Button Content="EPUB / Kindle" Margin="6" Padding="12,6" Command="{Binding PublishCommand}"/>
                    <Button Content="Project Archive" Margin="6" Padding="12,6" Command="{Binding PublishCommand}"/>
                </StackPanel>
            </TabItem>
            <TabItem Header="Publish">
                <StackPanel Orientation="Horizontal" Margin="6">
                    <TextBlock Text="Template:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox Width="260" ItemsSource="{Binding Templates}"
                              SelectedItem="{Binding SelectedTemplateId}"
                              DisplayMemberPath="." Margin="0,0,12,0"/>
                    <Button Content="Publish" Padding="12,6" Command="{Binding PublishCommand}"/>
                </StackPanel>
            </TabItem>
            <TabItem Header="Settings">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                    <StackPanel Margin="8" DataContext="{Binding Settings}">
                        <TextBlock Text="Application Settings" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>
                        
                        <GroupBox Header="General" Margin="0,0,0,8">
                            <StackPanel Margin="8">
                                <CheckBox Content="Auto-save projects" IsChecked="{Binding AutoSaveEnabled}" Margin="0,4"/>
                                <TextBlock Text="Auto-save interval (minutes):" Margin="0,8,0,2"/>
                                <TextBox Text="{Binding AutoSaveIntervalMinutes, UpdateSourceTrigger=PropertyChanged}" Width="60" HorizontalAlignment="Left"/>
                                <TextBlock Text="Max recent projects:" Margin="0,8,0,2"/>
                                <TextBox Text="{Binding MaxRecentProjects, UpdateSourceTrigger=PropertyChanged}" Width="60" HorizontalAlignment="Left"/>
                                <CheckBox Content="Check for updates" IsChecked="{Binding CheckForUpdates}" Margin="0,4"/>
                                <TextBlock Text="UI Language:" Margin="0,8,0,2"/>
                                <ComboBox ItemsSource="{Binding Languages}" SelectedItem="{Binding UiCultureCode}" Width="120" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Typography" Margin="0,0,0,8">
                            <StackPanel Margin="8">
                                <TextBlock Text="Default language:" Margin="0,0,0,2"/>
                                <ComboBox ItemsSource="{Binding Languages}" SelectedItem="{Binding DefaultLanguage}" Width="120" HorizontalAlignment="Left"/>
                                <CheckBox Content="Enable ligatures" IsChecked="{Binding EnableLigatures}" Margin="0,4"/>
                                <CheckBox Content="Enable kerning" IsChecked="{Binding EnableKerning}" Margin="0,4"/>
                                <CheckBox Content="Enable hyphenation" IsChecked="{Binding EnableHyphenation}" Margin="0,4"/>
                                <CheckBox Content="Enable optical alignment" IsChecked="{Binding EnableOpticalAlignment}" Margin="0,4"/>
                                <TextBlock Text="Drop cap lines:" Margin="0,8,0,2"/>
                                <TextBox Text="{Binding DropCapLines, UpdateSourceTrigger=PropertyChanged}" Width="60" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Validation" Margin="0,0,0,8">
                            <StackPanel Margin="8">
                                <CheckBox Content="Enable KDP checks" IsChecked="{Binding EnableKdpChecks}" Margin="0,4"/>
                                <CheckBox Content="Enable IngramSpark checks" IsChecked="{Binding EnableIngramSparkChecks}" Margin="0,4"/>
                                <TextBlock Text="KDP min pages:" Margin="0,8,0,2"/>
                                <TextBox Text="{Binding KdpMinPages, UpdateSourceTrigger=PropertyChanged}" Width="60" HorizontalAlignment="Left"/>
                                <TextBlock Text="KDP max pages:" Margin="0,8,0,2"/>
                                <TextBox Text="{Binding KdpMaxPages, UpdateSourceTrigger=PropertyChanged}" Width="60" HorizontalAlignment="Left"/>
                                <TextBlock Text="IngramSpark min pages:" Margin="0,8,0,2"/>
                                <TextBox Text="{Binding IngramSparkMinPages, UpdateSourceTrigger=PropertyChanged}" Width="60" HorizontalAlignment="Left"/>
                                <CheckBox Content="Treat warnings as errors" IsChecked="{Binding TreatWarningsAsErrors}" Margin="0,4"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Rendering" Margin="0,0,0,8">
                            <StackPanel Margin="8">
                                <TextBlock Text="Default image DPI:" Margin="0,0,0,2"/>
                                <TextBox Text="{Binding DefaultImageDpi, UpdateSourceTrigger=PropertyChanged}" Width="60" HorizontalAlignment="Left"/>
                                <CheckBox Content="Embed fonts" IsChecked="{Binding EmbedFonts}" Margin="0,4"/>
                                <CheckBox Content="Subset fonts" IsChecked="{Binding SubsetFonts}" Margin="0,4"/>
                                <TextBlock Text="Image quality (1-100):" Margin="0,8,0,2"/>
                                <TextBox Text="{Binding ImageQuality, UpdateSourceTrigger=PropertyChanged}" Width="60" HorizontalAlignment="Left"/>
                                <TextBlock Text="Color mode:" Margin="0,8,0,2"/>
                                <ComboBox ItemsSource="{Binding ColorModes}" SelectedItem="{Binding ColorMode}" Width="120" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Publishing" Margin="0,0,0,8">
                            <StackPanel Margin="8">
                                <TextBlock Text="Default export format:" Margin="0,0,0,2"/>
                                <ComboBox ItemsSource="{Binding ExportFormats}" SelectedItem="{Binding DefaultExportFormat}" Width="120" HorizontalAlignment="Left"/>
                                <CheckBox Content="Enable content integrity check" IsChecked="{Binding EnableContentIntegrity}" Margin="0,4"/>
                                <CheckBox Content="Always generate cover" IsChecked="{Binding AlwaysGenerateCover}" Margin="0,4"/>
                                <CheckBox Content="Always generate report" IsChecked="{Binding AlwaysGenerateReport}" Margin="0,4"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Theme" Margin="0,0,0,8">
                            <StackPanel Margin="8">
                                <TextBlock Text="Active theme:" Margin="0,0,0,2"/>
                                <ComboBox ItemsSource="{Binding Themes}" SelectedItem="{Binding ActiveTheme}" Width="120" HorizontalAlignment="Left"/>
                                <TextBlock Text="Accent color:" Margin="0,8,0,2"/>
                                <TextBox Text="{Binding AccentColor, UpdateSourceTrigger=PropertyChanged}" Width="100" HorizontalAlignment="Left"/>
                                <TextBlock Text="Font family:" Margin="0,8,0,2"/>
                                <TextBox Text="{Binding ThemeFontFamily, UpdateSourceTrigger=PropertyChanged}" Width="150" HorizontalAlignment="Left"/>
                                <TextBlock Text="Font size:" Margin="0,8,0,2"/>
                                <TextBox Text="{Binding ThemeFontSize, UpdateSourceTrigger=PropertyChanged}" Width="60" HorizontalAlignment="Left"/>
                                <CheckBox Content="Enable animations" IsChecked="{Binding EnableAnimations}" Margin="0,4"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Logging" Margin="0,0,0,8">
                            <StackPanel Margin="8">
                                <TextBlock Text="Minimum log level:" Margin="0,0,0,2"/>
                                <ComboBox SelectedItem="{Binding LogMinimumLevel}" Width="120" HorizontalAlignment="Left">
                                    <ComboBoxItem Content="Verbose"/>
                                    <ComboBoxItem Content="Debug"/>
                                    <ComboBoxItem Content="Information"/>
                                    <ComboBoxItem Content="Warning"/>
                                    <ComboBoxItem Content="Error"/>
                                </ComboBox>
                                <TextBlock Text="Max log file size (MB):" Margin="0,8,0,2"/>
                                <TextBox Text="{Binding LogMaxFileSizeMb, UpdateSourceTrigger=PropertyChanged}" Width="60" HorizontalAlignment="Left"/>
                                <CheckBox Content="Enable performance tracing" IsChecked="{Binding EnablePerformanceTracing}" Margin="0,4"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Backup" Margin="0,0,0,8">
                            <StackPanel Margin="8">
                                <CheckBox Content="Enable automatic backups" IsChecked="{Binding BackupEnabled}" Margin="0,4"/>
                                <TextBlock Text="Backup interval (minutes):" Margin="0,8,0,2"/>
                                <TextBox Text="{Binding BackupIntervalMinutes, UpdateSourceTrigger=PropertyChanged}" Width="60" HorizontalAlignment="Left"/>
                                <TextBlock Text="Max backups per project:" Margin="0,8,0,2"/>
                                <TextBox Text="{Binding MaxBackupsPerProject, UpdateSourceTrigger=PropertyChanged}" Width="60" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </GroupBox>

                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <Button Content="Save Settings" Padding="12,6" Command="{Binding SaveSettingsCommand}" Margin="0,0,8,0"/>
                            <Button Content="Reset to Defaults" Padding="12,6" Command="{Binding ResetDefaultsCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding Status}"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="{Binding PreviewModeLabel}"/>
            </StatusBarItem>
        </StatusBar>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" MinWidth="180"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*" MinWidth="400"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="320" MinWidth="240"/>
            </Grid.ColumnDefinitions>

            <!-- Book structure / layers / assets -->
            <DockPanel Grid.Column="0" Margin="4">
                <TabControl>
                    <TabItem Header="Structure">
                        <TreeView ItemsSource="{Binding Chapters}" Margin="2">
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate ItemsSource="{Binding Blocks}">
                                    <TextBlock Text="{Binding Title}"/>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </TabItem>
                    <TabItem Header="Bookmarks">
                        <ListBox ItemsSource="{Binding Bookmarks}"/>
                    </TabItem>
                    <TabItem Header="Assets">
                        <ListBox ItemsSource="{Binding Assets}"/>
                    </TabItem>
                </TabControl>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"/>

            <!-- Live preview surface -->
            <DockPanel Grid.Column="2" Margin="4">
                <ToolBar DockPanel.Dock="Top">
                    <TextBlock Text="Page" VerticalAlignment="Center" Margin="4,0"/>
                    <TextBox Width="48" Text="{Binding CurrentPage, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Text="{Binding PageCountLabel}" VerticalAlignment="Center" Margin="8,0"/>
                    <Button Content="◀" Command="{Binding PrevPageCommand}" Margin="4,0"/>
                    <Button Content="▶" Command="{Binding NextPageCommand}" Margin="4,0"/>
                    <Separator/>
                    <TextBlock Text="{Binding ZoomLabel}" VerticalAlignment="Center" Margin="8,0"/>
                </ToolBar>
                <Border Background="{DynamicResource CanvasBackground}">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="16">
                            <Border BorderBrush="#888" BorderThickness="1" Background="White"
                                    Width="{Binding PreviewPageWidth}" Height="{Binding PreviewPageHeight}"
                                    Padding="12">
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Top" Text="{Binding PreviewHeader}"
                                               FontStyle="Italic" FontSize="10" HorizontalAlignment="Center"
                                               Foreground="#666" Margin="0,0,0,8"/>
                                    <TextBlock DockPanel.Dock="Bottom" Text="{Binding PreviewFooter}"
                                               FontSize="10" HorizontalAlignment="Center"
                                               Foreground="#666" Margin="0,8,0,0"/>
                                    <TextBlock Text="{Binding PreviewMessage}" TextWrapping="Wrap"
                                               FontSize="12" LineHeight="18"/>
                                </DockPanel>
                            </Border>
                            <TextBlock Text="{Binding GuidesLabel}" Margin="0,8,0,0"
                                       FontSize="10" Foreground="#888" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </DockPanel>

            <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Stretch"/>

            <!-- Properties / Validation / Typography -->
            <TabControl Grid.Column="4" Margin="4">
                <TabItem Header="Properties">
                    <StackPanel Margin="8">
                        <TextBlock Text="Book Metadata" FontWeight="Bold"/>
                        <TextBlock Text="Title" Margin="0,8,0,2"/>
                        <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="Author" Margin="0,8,0,2"/>
                        <TextBox Text="{Binding Author, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="Template" Margin="0,8,0,2"/>
                        <ComboBox ItemsSource="{Binding Templates}"
                                  SelectedItem="{Binding SelectedTemplateId}"/>
                    </StackPanel>
                </TabItem>
                <TabItem Header="Validation">
                    <DockPanel Margin="4">
                        <TextBlock DockPanel.Dock="Top" Text="Preflight Findings" FontWeight="Bold" Margin="4"/>
                        <ListBox ItemsSource="{Binding Findings}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="0,2"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </TabItem>
                <TabItem Header="Preview">
                    <StackPanel Margin="8">
                        <TextBlock Text="{Binding PreviewDetails}" TextWrapping="Wrap"/>
                    </StackPanel>
                </TabItem>
            </TabControl>
        </Grid>
    </DockPanel>
</Window>
